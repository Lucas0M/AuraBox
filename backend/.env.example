# ---------------------------------------------
# Banco de dados
# ---------------------------------------------
DATABASE_URL="postgresql://usuario:senha@localhost:5432/capsula_do_tempo"

# ---------------------------------------------
# Servidor
# ---------------------------------------------
PORT=3333
NODE_ENV=development

# URL do frontend, usada para montar links públicos da cápsula
# e nas URLs de retorno/conclusão do checkout
FRONTEND_URL="http://localhost:5173"

# ---------------------------------------------
# AbacatePay (pagamentos via PIX)
# https://abacatepay.com
# ---------------------------------------------
ABACATEPAY_API_KEY="abc_dev_sua_chave_aqui"

# Secret que você escolhe ao criar o webhook no dashboard da AbacatePay
# (vai na query string da URL do webhook, ex: ?webhookSecret=ESSE_VALOR)
ABACATEPAY_WEBHOOK_SECRET="escolha-um-valor-secreto-aqui"

# ---------------------------------------------
# Cloudinary (upload de imagens)
# https://cloudinary.com
# ---------------------------------------------
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"
