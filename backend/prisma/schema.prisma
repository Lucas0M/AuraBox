generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CapsuleStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  ARCHIVED
}

enum CheckoutSessionStatus {
  PENDING
  PAID
  CANCELED
}

model Capsule {
  id             String               @id @default(uuid())
  title          String
  slug           String               @unique
  status         CapsuleStatus        @default(DRAFT)
  recipientName  String?
  occasion       String?
  songUrl        String?
  letter         String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  timelineItems  TimelineItem[]
  checkoutSession CheckoutSession?

  @@index([slug])
  @@index([status])
}

model TimelineItem {
  id         String   @id @default(uuid())
  capsuleId  String
  imageUrl   String
  caption    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  capsule    Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([sortOrder])
}

model CheckoutSession {
  id          String                @id @default(uuid())
  capsuleId   String                @unique
  provider    String                @default("manual")
  status      CheckoutSessionStatus @default(PENDING)
  checkoutUrl String
  amount      Int                   @default(0)
  currency    String                @default("BRL")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  capsule     Capsule               @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
}
